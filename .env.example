# Modèle à copier → renommer en .env et remplir vos valeurs
# 1. Activer IMAP dans Gmail : Paramètres → Transfert et POP/IMAP
# 2. Créer un mot de passe d'application : https://myaccount.google.com/apppasswords

GMAIL_USER=votre.adresse@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Sync GitHub automatique après modification de data.csv
GIT_AUTO_PUSH=1
GIT_REMOTE=origin
GIT_BRANCH=main
